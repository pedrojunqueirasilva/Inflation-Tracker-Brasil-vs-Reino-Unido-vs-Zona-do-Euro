{
  "buildCommand": "bash build.sh",
  "outputDirectory": "public",
  "installCommand": "echo 'Python project — pip install handled in build.sh'",
  "framework": null,
  "headers": [
    {
      "source": "/figures/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
